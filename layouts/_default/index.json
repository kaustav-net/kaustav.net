{{- $.Scratch.Add "index" slice -}}
{{- range where .Site.RegularPages "Section" "posts" -}}
  {{- $link := .Permalink -}}
  {{- $external := false -}}
  {{- with .Params.externalUrl -}}{{- $link = . -}}{{- $external = true -}}{{- end -}}
  {{- $.Scratch.Add "index" (dict "title" .Title "tags" .Params.tags "description" .Description "permalink" $link "external" $external "content" (.Plain | htmlUnescape) "date" (.Date.Format "2006-01-02")) -}}
{{- end -}}
{{- $.Scratch.Get "index" | jsonify -}}
