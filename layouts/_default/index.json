{{- $.Scratch.Add "index" slice -}}
{{- range where .Site.RegularPages "Section" "posts" -}}
  {{- $.Scratch.Add "index" (dict "title" .Title "tags" .Params.tags "description" .Description "permalink" .Permalink "content" (.Plain | htmlUnescape) "date" (.Date.Format "2006-01-02")) -}}
{{- end -}}
{{- $.Scratch.Get "index" | jsonify -}}
